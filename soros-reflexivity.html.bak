<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Soros AI Reflexivity OS · 黑森船长</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Noto+Serif+SC:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="soros-data.js" onerror="console.warn('soros-data.js not loaded - run fetch_fred.py first')"></script>
<style>
  :root {
    --bg: #e8eff7;
    --bg-deep: #dde6f0;
    --card: #f4f7fb;
    --text: #1a2942;
    --text-mute: #5a6a82;
    --gold: #b8923a;
    --gold-soft: #c9a558;
    --divider: #c5d0de;
    --green: #2d7a3e;
    --warn: #c47a3a;
    --red: #a83838;
    --shadow: 0 1px 3px rgba(26, 41, 66, 0.08);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Noto Serif SC', 'Cormorant Garamond', serif;
    font-weight: 400;
    line-height: 1.7;
    min-height: 100vh;
  }

  /* ===== TOPBAR ===== */
  .topbar {
    background: var(--bg-deep);
    border-bottom: 1px solid var(--divider);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .topbar-brand {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding: 14px 24px;
    border-bottom: 1px solid var(--divider);
  }

  .brand-left {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
  }

  .brand-mark {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.3em;
    color: var(--gold);
  }

  .brand-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 500;
    color: var(--text);
  }

  .brand-cn {
    font-family: 'Noto Serif SC', serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
  }

  .brand-tag {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 11px;
    color: var(--text-mute);
  }

  .nav {
    display: flex;
    overflow-x: auto;
    padding: 0 12px;
    scrollbar-width: thin;
  }

  .nav::-webkit-scrollbar { height: 4px; }
  .nav::-webkit-scrollbar-thumb { background: var(--gold-soft); border-radius: 2px; }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px;
    cursor: pointer;
    transition: all 0.2s ease;
    border-bottom: 2px solid transparent;
    user-select: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav-item:hover {
    background: rgba(184, 146, 58, 0.06);
  }

  .nav-item.active {
    background: var(--card);
    border-bottom-color: var(--gold);
  }

  .nav-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--gold);
    line-height: 1;
  }

  .nav-label {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .nav-label .cn {
    font-family: 'Noto Serif SC', serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.2;
  }

  .nav-label .en {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 9px;
    color: var(--text-mute);
    line-height: 1;
  }

  .nav-item.active .nav-label .cn {
    color: var(--gold);
  }

  /* ===== DATA STATUS (右上角) ===== */
  .data-status {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 6px 14px;
    background: var(--card);
    border-left: 2px solid var(--gold);
    border-radius: 0;
  }

  .data-status-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--gold);
    text-transform: uppercase;
  }

  .status-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
  }

  .status-label {
    color: var(--text-mute);
    letter-spacing: 0.12em;
  }

  .status-val {
    color: var(--text);
    font-weight: 500;
  }

  .status-val.alert { color: var(--warn); }
  .status-val.danger { color: var(--red); font-weight: 600; }

  .status-trigger {
    font-family: 'Noto Serif SC', serif;
    font-size: 11px;
    color: var(--green);
    font-weight: 500;
    padding-left: 12px;
    border-left: 1px dashed var(--divider);
  }

  .status-trigger.warn { color: var(--warn); }
  .status-trigger.danger { color: var(--red); }

  /* ===== MAIN ===== */
  .main {
    padding: 32px 24px 64px;
    max-width: 1280px;
    margin: 0 auto;
  }

  .tab-content {
    display: none;
    animation: fadeIn 0.3s ease;
  }

  .tab-content.active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ===== TAB HEADER ===== */
  .tab-header {
    border-top: 2px solid var(--gold);
    padding: 28px 0 24px;
    margin-bottom: 32px;
    border-bottom: 1px solid var(--divider);
  }

  .tab-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .tab-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 28px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 6px;
  }

  .tab-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 16px;
    color: var(--text-mute);
  }

  /* ===== SHARED COMPONENTS ===== */
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    background: var(--card);
    box-shadow: var(--shadow);
  }

  th {
    text-align: left;
    padding: 12px 14px;
    background: var(--bg-deep);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    color: var(--text-mute);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--divider);
  }

  td {
    padding: 14px;
    border-bottom: 1px solid var(--divider);
    vertical-align: top;
    line-height: 1.6;
  }

  tr:last-child td { border-bottom: none; }

  td.code-cell {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
    color: var(--gold);
    white-space: nowrap;
  }

  td.tight {
    width: 1%;
    white-space: nowrap;
  }

  .layer {
    background: var(--card);
    border: 1px solid var(--divider);
    border-left: 4px solid var(--gold);
    padding: 24px 28px;
    box-shadow: var(--shadow);
    margin-bottom: 20px;
  }

  .layer-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px dashed var(--divider);
  }

  .layer-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 17px;
    font-weight: 600;
    color: var(--text);
  }

  .layer-title .code {
    font-family: 'JetBrains Mono', monospace;
    color: var(--gold);
    font-size: 13px;
    margin-right: 12px;
  }

  .layer-weight {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--gold);
    letter-spacing: 0.1em;
  }

  .layer-thesis {
    font-size: 13px;
    color: var(--text-mute);
    font-style: italic;
    margin-bottom: 16px;
    padding-left: 12px;
    border-left: 2px solid var(--gold-soft);
  }

  .short-layer { border-left-color: var(--red); }
  .short-layer .layer-title .code,
  .short-layer .layer-weight { color: var(--red); }
  .short-layer .layer-thesis { border-left-color: var(--red); }
  .short-layer td.code-cell { color: var(--red); }

  /* ===== PHASE TRACK ===== */
  .phase-bar {
    background: var(--card);
    border: 1px solid var(--divider);
    padding: 24px;
    box-shadow: var(--shadow);
    margin-bottom: 24px;
  }

  .phase-intro {
    font-size: 13px;
    color: var(--text-mute);
    margin-bottom: 16px;
  }

  .phase-track {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 4px;
  }

  .phase-step {
    text-align: center;
    padding: 12px 4px;
    background: var(--bg-deep);
    border-top: 3px solid transparent;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--text-mute);
    letter-spacing: 0.1em;
  }

  .phase-step.passed {
    background: rgba(184, 146, 58, 0.08);
    border-top-color: var(--gold-soft);
  }

  .phase-step.current {
    background: var(--gold);
    color: #fff;
    border-top-color: var(--gold);
    font-weight: 600;
  }

  .phase-step .num {
    display: block;
    font-size: 18px;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    margin-bottom: 4px;
  }

  .evidence-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .evidence-card {
    padding: 16px;
    background: var(--card);
    border: 1px solid var(--divider);
    border-left: 2px solid var(--gold-soft);
  }

  .evidence-card .label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--text-mute);
    letter-spacing: 0.15em;
    margin-bottom: 6px;
  }

  .evidence-card .value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 4px;
    line-height: 1;
  }

  .evidence-card .note {
    font-size: 11px;
    color: var(--text-mute);
  }

  /* ===== TRANSMISSION CHAIN ===== */
  .transmission {
    background: var(--card);
    border: 1px solid var(--divider);
    padding: 28px;
    box-shadow: var(--shadow);
  }

  .chain-intro {
    font-size: 13px;
    color: var(--text-mute);
    margin-bottom: 20px;
    padding-left: 12px;
    border-left: 2px solid var(--gold);
  }

  .chain {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .chain-node {
    display: grid;
    grid-template-columns: 50px 1fr 90px;
    gap: 14px;
    align-items: center;
    padding: 14px 18px;
    background: var(--bg);
    border-left: 3px solid var(--gold-soft);
  }

  .chain-node .step {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 500;
    color: var(--gold);
    text-align: center;
    line-height: 1;
  }

  .chain-node .content {
    font-size: 13px;
    color: var(--text);
  }

  .chain-node .timing {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--text-mute);
    letter-spacing: 0.1em;
    text-align: right;
  }

  .chain-arrow {
    text-align: center;
    color: var(--gold);
    font-size: 14px;
    line-height: 1;
  }

  .chain-conclusion {
    margin-top: 20px;
    padding: 16px 20px;
    background: var(--bg-deep);
    border-left: 3px solid var(--gold);
    font-size: 13px;
    line-height: 1.7;
  }

  /* ===== SIGNAL CARDS ===== */
  .signal-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  .signal-card {
    background: var(--card);
    border: 1px solid var(--divider);
    padding: 18px 20px;
    position: relative;
  }

  .signal-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--green);
  }

  .signal-card.warn::before { background: var(--warn); }
  .signal-card.red::before { background: var(--red); }

  .signal-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 4px;
  }

  .signal-name {
    font-family: 'Noto Serif SC', serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 12px;
  }

  .signal-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px 0;
    font-size: 12px;
    border-bottom: 1px dashed var(--divider);
  }

  .signal-row:last-child { border-bottom: none; }

  .signal-row .key {
    color: var(--text-mute);
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
  }

  .signal-row .val {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    color: var(--text);
  }

  .status-pill {
    display: inline-block;
    padding: 2px 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.15em;
    border-radius: 2px;
  }

  .pill-green { background: rgba(45, 122, 62, 0.12); color: var(--green); }
  .pill-warn { background: rgba(196, 122, 58, 0.12); color: var(--warn); }
  .pill-red { background: rgba(168, 56, 56, 0.12); color: var(--red); }

  /* ===== ACTION RULES ===== */
  .action-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-bottom: 28px;
  }

  .action-card {
    background: var(--card);
    border: 1px solid var(--divider);
    padding: 22px 18px;
    text-align: center;
  }

  .action-trigger {
    font-family: 'Cormorant Garamond', serif;
    font-size: 38px;
    font-weight: 500;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 4px;
  }

  .action-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--text-mute);
    letter-spacing: 0.15em;
    margin-bottom: 14px;
  }

  .action-desc {
    font-size: 12px;
    color: var(--text);
    line-height: 1.5;
    padding-top: 14px;
    border-top: 1px solid var(--divider);
  }

  /* ===== TODAY LIST ===== */
  .today-list {
    background: var(--card);
    border: 1px solid var(--divider);
    border-left: 4px solid var(--gold);
    padding: 24px 32px;
    box-shadow: var(--shadow);
  }

  .today-item {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px dashed var(--divider);
  }

  .today-item:last-child { border-bottom: none; padding-bottom: 0; }
  .today-item:first-child { padding-top: 0; }

  .today-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    color: var(--gold);
    font-weight: 500;
    line-height: 1;
  }

  .today-content strong {
    font-family: 'Noto Serif SC', serif;
    font-weight: 600;
    color: var(--text);
    display: block;
    margin-bottom: 4px;
  }

  .today-content .detail {
    font-size: 12px;
    color: var(--text-mute);
    font-family: 'JetBrains Mono', monospace;
  }

  /* ===== QUOTE ===== */
  .quote {
    background: linear-gradient(180deg, var(--card) 0%, var(--bg-deep) 100%);
    border: 1px solid var(--divider);
    border-top: 3px solid var(--gold);
    padding: 32px 36px;
    text-align: center;
    margin-top: 24px;
  }

  .quote-mark {
    font-family: 'Cormorant Garamond', serif;
    font-size: 42px;
    color: var(--gold);
    line-height: 0.5;
    margin-bottom: 14px;
  }

  .quote-text {
    font-family: 'Noto Serif SC', serif;
    font-size: 17px;
    line-height: 1.7;
    color: var(--text);
    max-width: 720px;
    margin: 0 auto 14px;
    font-weight: 500;
  }

  .quote-attr {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.25em;
    color: var(--gold);
    text-transform: uppercase;
  }

  /* ===== DISCIPLINE TAB ===== */
  .cadence-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  .cadence-card {
    background: var(--card);
    border: 1px solid var(--divider);
    border-top: 3px solid var(--gold);
    padding: 22px 24px;
    box-shadow: var(--shadow);
  }

  .cadence-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px dashed var(--divider);
  }

  .cadence-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
  }

  .cadence-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--gold);
    letter-spacing: 0.15em;
  }

  .cadence-list {
    list-style: none;
    padding: 0;
  }

  .cadence-list li {
    padding: 7px 0 7px 18px;
    font-size: 13px;
    color: var(--text);
    border-bottom: 1px dotted var(--divider);
    position: relative;
    line-height: 1.5;
  }

  .cadence-list li:last-child { border-bottom: none; }

  .cadence-list li::before {
    content: '◆';
    position: absolute;
    left: 0;
    top: 7px;
    color: var(--gold);
    font-size: 8px;
  }

  .cadence-list li .meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--text-mute);
    margin-left: 6px;
  }

  .sop-table {
    margin-bottom: 24px;
  }

  .sop-table .level-1 td:first-child { color: var(--green); font-weight: 600; }
  .sop-table .level-2 td:first-child { color: var(--warn); font-weight: 600; }
  .sop-table .level-3 td:first-child { color: var(--red); font-weight: 600; }
  .sop-table .level-4 td:first-child { color: var(--red); font-weight: 700; }

  .source-table td.code-cell { font-size: 11px; }

  .aux-section {
    background: var(--card);
    border: 1px solid var(--divider);
    border-left: 3px solid var(--gold-soft);
    padding: 20px 24px;
    margin-bottom: 24px;
  }

  .aux-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 12px;
  }

  .aux-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .aux-item {
    padding: 10px 14px;
    background: var(--bg);
    font-size: 12px;
  }

  .aux-item .name {
    font-family: 'Noto Serif SC', serif;
    font-weight: 600;
    color: var(--text);
    display: block;
    margin-bottom: 3px;
  }

  .aux-item .src {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--text-mute);
  }

  /* Mobile */
  @media (max-width: 900px) {
    .cadence-grid { grid-template-columns: 1fr; }
    .aux-grid { grid-template-columns: 1fr; }
  }
    body { flex-direction: column; }
    .sidebar {
      position: relative;
      width: 100%;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--divider);
      padding: 20px 0;
    }
    .main { margin-left: 0; padding: 24px; max-width: 100vw; }
    .nav { display: flex; flex-wrap: wrap; gap: 4px; }
    .nav-item { flex: 1 1 auto; min-width: 130px; }
    .sidebar-footer { display: none; }
    .evidence-grid { grid-template-columns: 1fr; }
    .signal-grid { grid-template-columns: 1fr; }
    .action-grid { grid-template-columns: repeat(2, 1fr); }
    .phase-track { grid-template-columns: repeat(4, 1fr); }
  }
</style>
</head>
<body>

  <!-- ===== TOPBAR ===== -->
  <header class="topbar">
    <div class="topbar-brand">
      <div class="brand-left">
        <span class="brand-mark">SOROS REFLEXIVITY OS · V1.2</span>
        <span class="brand-name">Captain Hessen</span>
        <span class="brand-cn">黑森船长</span>
        <span class="brand-tag">锚定确定性</span>
      </div>
      <div class="data-status">
        <span class="data-status-title">实时数据</span>
        <div class="status-row">
          <span class="status-label">更新</span>
          <span class="status-val" id="last-update">未连接</span>
        </div>
        <div class="status-row">
          <span class="status-label">翻转</span>
          <span class="status-val" id="flipped-count">— / 7</span>
        </div>
        <div class="status-trigger" id="trigger-level">等待数据加载</div>
      </div>
    </div>

    <nav class="nav">
