  </main>

<script>
  // Tab switching
  const navItems = document.querySelectorAll('.nav-item');
  const tabContents = document.querySelectorAll('.tab-content');

  navItems.forEach(item => {
    item.addEventListener('click', () => {
      const tab = item.dataset.tab;
      navItems.forEach(n => n.classList.remove('active'));
      tabContents.forEach(c => c.classList.remove('active'));
      item.classList.add('active');
      document.getElementById('tab-' + tab).classList.add('active');
      // Scroll main to top
      document.querySelector('.main').scrollTo({ top: 0, behavior: 'smooth' });
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  // ===== Auto-update from FRED data =====
  function applyLiveData() {
    if (typeof FRED_DATA === 'undefined') {
      console.log('FRED_DATA not loaded - HTML using default values');
      return;
    }

    // Update sidebar status
    const updateEl = document.getElementById('last-update');
    if (updateEl) updateEl.textContent = FRED_DATA.updated_at.split(' ')[0] + ' ' + FRED_DATA.updated_at.split(' ')[1];

    const countEl = document.getElementById('flipped-count');
    if (countEl) {
      const total = FRED_DATA.flipped_total || 7;
      countEl.textContent = `${FRED_DATA.flipped_count} / ${total}`;
      if (FRED_DATA.flipped_count >= 3) countEl.className = 'status-val danger';
      else if (FRED_DATA.flipped_count >= 2) countEl.className = 'status-val alert';
    }

    // Update trigger level message
    const triggerEl = document.getElementById('trigger-level');
    if (triggerEl) {
      const f = FRED_DATA.flipped_count;
      if (f >= 5) {
        triggerEl.textContent = '⚠ 全面切换净空头';
        triggerEl.className = 'status-trigger danger';
      } else if (f >= 3) {
        triggerEl.textContent = '⚠ 空头变主仓';
        triggerEl.className = 'status-trigger danger';
      } else if (f >= 2) {
        triggerEl.textContent = '决策窗口开';
        triggerEl.className = 'status-trigger warn';
      } else {
        triggerEl.textContent = '维持当前结构';
        triggerEl.className = 'status-trigger';
      }
    }

    // Update each signal card
    for (const [signalId, data] of Object.entries(FRED_DATA.signals || {})) {
      const card = document.querySelector(`[data-signal="${signalId}"]`);
      if (!card) continue;

      // Update current value
      const currentEl = card.querySelector('[data-field="current"]');
      if (currentEl && data.current) currentEl.textContent = data.current;

      // Update delta
      const deltaEl = card.querySelector('[data-field="delta"]');
      if (deltaEl && data.delta_30d) deltaEl.textContent = data.delta_30d;

      // Update status pill
      const statusEl = card.querySelector('[data-field="status"]');
      if (statusEl && data.status) {
        statusEl.textContent = data.status;
        statusEl.className = `status-pill ${data.pill}`;
      }

      // Update card border color via class
      const baseClass = 'signal-card';
      if (data.pill === 'pill-red') card.className = baseClass + ' red';
      else if (data.pill === 'pill-warn') card.className = baseClass + ' warn';
      else card.className = baseClass;
    }
  }

  document.addEventListener('DOMContentLoaded', applyLiveData);
</script>
</body>
</html>
